{
  "name": "@webmcpui/core",
  "version": "0.3.0",
  "description": "Agent-aware, framework-agnostic web components for the WebMCP era — accessible, form-associated controls an AI agent can fill, with Standard Schema validation.",
  "license": "MIT",
  "author": "Gary Pfaff (Pfaff Digital)",
  "homepage": "https://webmcpui.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webmcpui/webmcpui.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/webmcpui/webmcpui/issues"
  },
  "keywords": [
    "webmcp",
    "web-components",
    "custom-elements",
    "ai-agents",
    "modelcontext",
    "forms",
    "standard-schema",
    "lit"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "unpkg": "./dist/webmcpui.global.js",
  "jsdelivr": "./dist/webmcpui.global.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node scripts/append-global-dts.mjs",
    "typecheck": "tsc --noEmit",
    "test": "wtr",
    "test:watch": "wtr --watch",
    "test:smoke": "node scripts/smoke.mjs",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "playwright": "^1.60.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
