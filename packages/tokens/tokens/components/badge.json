{
  "components": {
    "badge": {
      "primary-bg": { "$type": "color", "$value": "{base.primary}" },
      "primary-text": { "$type": "color", "$value": "{base.primary-foreground}" },
      "secondary-bg": { "$type": "color", "$value": "{base.secondary}" },
      "secondary-text": { "$type": "color", "$value": "{base.secondary-foreground}" },
      "destructive-bg": { "$type": "color", "$value": "{base.destructive}" },
      "destructive-text": { "$type": "color", "$value": "{base.destructive-foreground}" },
      "outline-text": { "$type": "color", "$value": "{base.foreground}" },
      "outline-border": { "$type": "color", "$value": "{base.border}" },

      "radius": { "$type": "dimension", "$value": "999px" },
      "padding": { "$type": "dimension", "$value": "0.125rem 0.5rem" },
      "gap": { "$type": "dimension", "$value": "0.25rem" },
      "font-size": { "$type": "dimension", "$value": "0.75rem" },
      "font-weight": { "$type": "fontWeight", "$value": 500 }
    }
  }
}
