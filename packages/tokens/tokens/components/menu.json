{
  "components": {
    "menu": {
      "bg": { "$type": "color", "$value": "{base.popover}" },
      "text": { "$type": "color", "$value": "{base.popover-foreground}" },
      "border": { "$type": "color", "$value": "{base.border}" },

      "trigger-bg": { "$type": "color", "$value": "{base.background}" },
      "trigger-bg-hover": { "$type": "color", "$value": "{base.accent}" },
      "trigger-text": { "$type": "color", "$value": "{base.foreground}" },
      "trigger-border": { "$type": "color", "$value": "{base.border}" },

      "item-bg-hover": { "$type": "color", "$value": "{base.accent}" },
      "item-text-hover": { "$type": "color", "$value": "{base.accent-foreground}" },
      "item-disabled-opacity": { "$type": "number", "$value": 0.5 },

      "radius": { "$type": "dimension", "$value": "{base.radius}" },
      "item-radius": { "$type": "dimension", "$value": "0.4rem" },
      "min-width": { "$type": "dimension", "$value": "11rem" },
      "offset": { "$type": "dimension", "$value": "0.25rem" },
      "padding": { "$type": "dimension", "$value": "0.25rem" },
      "item-padding": { "$type": "dimension", "$value": "0.4rem 0.6rem" },
      "item-gap": { "$type": "dimension", "$value": "0.5rem" },

      "trigger-height": { "$type": "dimension", "$value": "2.25rem" },
      "trigger-padding-x": { "$type": "dimension", "$value": "1rem" },
      "trigger-gap": { "$type": "dimension", "$value": "0.375rem" },
      "trigger-font-weight": { "$type": "fontWeight", "$value": 500 },

      "font-family": {
        "$type": "fontFamily",
        "$value": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
      },
      "font-size": { "$type": "dimension", "$value": "0.875rem" }
    }
  }
}
