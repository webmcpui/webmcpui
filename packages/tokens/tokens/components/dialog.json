{
  "components": {
    "dialog": {
      "bg": { "$type": "color", "$value": "{base.popover}" },
      "text": { "$type": "color", "$value": "{base.popover-foreground}" },
      "border": { "$type": "color", "$value": "{base.border}" },
      "backdrop": {
        "$type": "color",
        "$value": "color-mix(in oklch, oklch(0 0 0) 50%, transparent)"
      },

      "border-width": { "$type": "dimension", "$value": "1px" },
      "radius": { "$type": "dimension", "$value": "{base.radius}" },
      "padding": { "$type": "dimension", "$value": "1.5rem" },
      "width": { "$type": "dimension", "$value": "min(92vw, 32rem)" },
      "max-width": { "$type": "dimension", "$value": "32rem" },
      "max-height": { "$type": "dimension", "$value": "85dvh" },

      "font-family": {
        "$type": "fontFamily",
        "$value": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
      },

      "transition-duration": { "$type": "duration", "$value": "180ms" },
      "transition-easing": {
        "$type": "cubicBezier",
        "$value": "cubic-bezier(0.4, 0, 0.2, 1)"
      }
    }
  }
}
