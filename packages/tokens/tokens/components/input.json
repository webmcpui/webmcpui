{
  "components": {
    "input": {
      "bg": { "$type": "color", "$value": "{base.background}" },
      "bg-hover": { "$type": "color", "$value": "{base.background}" },
      "bg-focus": { "$type": "color", "$value": "{base.background}" },
      "bg-disabled": { "$type": "color", "$value": "{base.muted}" },
      "bg-readonly": { "$type": "color", "$value": "{base.muted}" },

      "border": { "$type": "color", "$value": "{base.input}" },
      "border-hover": { "$type": "color", "$value": "{base.border}" },
      "border-focus": { "$type": "color", "$value": "{base.ring}" },
      "border-error": { "$type": "color", "$value": "{base.destructive}" },
      "border-success": { "$type": "color", "$value": "oklch(0.627 0.13 160)" },
      "border-disabled": { "$type": "color", "$value": "{base.border}" },

      "text": { "$type": "color", "$value": "{base.foreground}" },
      "text-disabled": { "$type": "color", "$value": "{base.muted-foreground}" },
      "placeholder": { "$type": "color", "$value": "{base.muted-foreground}" },
      "icon": { "$type": "color", "$value": "{base.muted-foreground}" },
      "icon-disabled": { "$type": "color", "$value": "{base.muted-foreground}" },
      "label": { "$type": "color", "$value": "{base.foreground}" },
      "helper": { "$type": "color", "$value": "{base.muted-foreground}" },
      "error-text": { "$type": "color", "$value": "{base.destructive}" },
      "success-text": { "$type": "color", "$value": "oklch(0.627 0.13 160)" },

      "padding-x": { "$type": "dimension", "$value": "0.75rem" },
      "padding-y": { "$type": "dimension", "$value": "0.5rem" },
      "gap-icon": { "$type": "dimension", "$value": "0.5rem" },
      "gap-label": { "$type": "dimension", "$value": "0.375rem" },
      "gap-helper": { "$type": "dimension", "$value": "0.375rem" },

      "height-sm": { "$type": "dimension", "$value": "2rem" },
      "height-md": { "$type": "dimension", "$value": "2.25rem" },
      "height-lg": { "$type": "dimension", "$value": "2.75rem" },
      "icon-size": { "$type": "dimension", "$value": "1rem" },
      "border-width": { "$type": "dimension", "$value": "1px" },

      "font-family": {
        "$type": "fontFamily",
        "$value": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
      },
      "font-size": { "$type": "dimension", "$value": "0.875rem" },
      "font-size-label": { "$type": "dimension", "$value": "0.875rem" },
      "font-size-helper": { "$type": "dimension", "$value": "0.8125rem" },
      "font-weight-label": { "$type": "fontWeight", "$value": 500 },
      "line-height": { "$type": "dimension", "$value": "1.25rem" },

      "radius": { "$type": "dimension", "$value": "{base.radius}" },

      "transition-duration": { "$type": "duration", "$value": "150ms" },
      "transition-easing": { "$type": "cubicBezier", "$value": "cubic-bezier(0.4, 0, 0.2, 1)" }
    }
  }
}
