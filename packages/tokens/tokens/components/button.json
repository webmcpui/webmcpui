{
  "components": {
    "button": {
      "primary-bg": { "$type": "color", "$value": "{base.primary}" },
      "primary-bg-hover": {
        "$type": "color",
        "$value": "color-mix(in oklch, {base.primary} 90%, transparent)"
      },
      "primary-text": { "$type": "color", "$value": "{base.primary-foreground}" },

      "secondary-bg": { "$type": "color", "$value": "{base.secondary}" },
      "secondary-bg-hover": {
        "$type": "color",
        "$value": "color-mix(in oklch, {base.secondary} 80%, {base.foreground})"
      },
      "secondary-text": { "$type": "color", "$value": "{base.secondary-foreground}" },

      "destructive-bg": { "$type": "color", "$value": "{base.destructive}" },
      "destructive-bg-hover": {
        "$type": "color",
        "$value": "color-mix(in oklch, {base.destructive} 90%, transparent)"
      },
      "destructive-text": { "$type": "color", "$value": "{base.destructive-foreground}" },

      "outline-bg": { "$type": "color", "$value": "{base.background}" },
      "outline-bg-hover": { "$type": "color", "$value": "{base.accent}" },
      "outline-text": { "$type": "color", "$value": "{base.foreground}" },
      "outline-text-hover": { "$type": "color", "$value": "{base.accent-foreground}" },
      "outline-border": { "$type": "color", "$value": "{base.border}" },

      "ghost-text": { "$type": "color", "$value": "{base.foreground}" },
      "ghost-text-hover": { "$type": "color", "$value": "{base.accent-foreground}" },
      "ghost-bg-hover": { "$type": "color", "$value": "{base.accent}" },

      "radius": { "$type": "dimension", "$value": "{base.radius}" },
      "border-width": { "$type": "dimension", "$value": "1px" },
      "disabled-opacity": { "$type": "number", "$value": 0.5 },

      "gap": { "$type": "dimension", "$value": "0.5rem" },
      "padding-x-sm": { "$type": "dimension", "$value": "0.75rem" },
      "padding-x-md": { "$type": "dimension", "$value": "1rem" },
      "padding-x-lg": { "$type": "dimension", "$value": "1.5rem" },

      "height-sm": { "$type": "dimension", "$value": "2rem" },
      "height-md": { "$type": "dimension", "$value": "2.25rem" },
      "height-lg": { "$type": "dimension", "$value": "2.5rem" },

      "font-family": {
        "$type": "fontFamily",
        "$value": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
      },
      "font-size": { "$type": "dimension", "$value": "0.875rem" },
      "font-weight": { "$type": "fontWeight", "$value": 500 },

      "transition-duration": { "$type": "duration", "$value": "150ms" },
      "transition-easing": {
        "$type": "cubicBezier",
        "$value": "cubic-bezier(0.4, 0, 0.2, 1)"
      }
    }
  }
}
