{
  "components": {
    "popover": {
      "bg": { "$type": "color", "$value": "{base.popover}" },
      "text": { "$type": "color", "$value": "{base.popover-foreground}" },
      "border": { "$type": "color", "$value": "{base.border}" },

      "radius": { "$type": "dimension", "$value": "{base.radius}" },
      "padding": { "$type": "dimension", "$value": "0.75rem 0.875rem" },
      "max-width": { "$type": "dimension", "$value": "18rem" },
      "offset": { "$type": "dimension", "$value": "0.4rem" },

      "font-family": {
        "$type": "fontFamily",
        "$value": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
      },
      "font-size": { "$type": "dimension", "$value": "0.875rem" }
    }
  }
}
