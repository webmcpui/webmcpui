{
  "components": {
    "toast": {
      "bg": { "$type": "color", "$value": "{base.popover}" },
      "text": { "$type": "color", "$value": "{base.popover-foreground}" },
      "message": { "$type": "color", "$value": "{base.muted-foreground}" },
      "border": { "$type": "color", "$value": "{base.border}" },

      "accent-info": { "$type": "color", "$value": "{base.primary}" },
      "accent-success": { "$type": "color", "$value": "oklch(0.627 0.13 160)" },
      "accent-warning": { "$type": "color", "$value": "oklch(0.7 0.16 75)" },
      "accent-error": { "$type": "color", "$value": "{base.destructive}" },

      "radius": { "$type": "dimension", "$value": "{base.radius}" },
      "padding": { "$type": "dimension", "$value": "0.75rem 0.875rem" },
      "max-width": { "$type": "dimension", "$value": "22rem" },
      "gap": { "$type": "dimension", "$value": "0.5rem" },
      "item-gap": { "$type": "dimension", "$value": "0.625rem" },
      "inset": { "$type": "dimension", "$value": "1rem" },

      "font-family": {
        "$type": "fontFamily",
        "$value": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
      },
      "font-size": { "$type": "dimension", "$value": "0.875rem" }
    }
  }
}
