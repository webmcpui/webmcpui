{
  "name": "@webmcpui/tokens",
  "version": "0.2.1",
  "description": "Design token dictionary for webmcpui — source of truth in tokens/*.json, built with Style Dictionary into CSS custom properties, TS types, and a Figma import.",
  "license": "MIT",
  "author": "Gary Pfaff (Pfaff Digital)",
  "homepage": "https://webmcpui.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webmcpui/webmcpui.git",
    "directory": "packages/tokens"
  },
  "bugs": {
    "url": "https://github.com/webmcpui/webmcpui/issues"
  },
  "keywords": [
    "webmcpui",
    "design-tokens",
    "css-custom-properties",
    "style-dictionary"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/js/tokens.d.ts",
      "import": "./dist/js/tokens.js"
    },
    "./css": {
      "types": "./dist/css/tokens.d.ts",
      "default": "./dist/css/tokens.css"
    },
    "./figma": "./dist/figma/tokens.json"
  },
  "files": [
    "dist",
    "tokens"
  ],
  "scripts": {
    "build": "node config/build.js",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "style-dictionary": "^4.3.0"
  }
}
